# Copy this file to community-brain/config/.env and fill in the values you need.
# When running the retrieval-server via `docker compose up`, the compose file
# loads this file directly (env_file directive). Values here land inside the
# container and are read by the retrieval server at startup / request time.
#
# Precedence for any variable:
#   1. Shell env at `docker compose up` time  (highest)
#   2. Root-level ./.env  (read by compose for ${VAR} interpolation)
#   3. community-brain/config/.env  (this file; loaded via env_file)
#   4. compose `environment:` literal defaults  (lowest)

# --- Required for retrieval server deployment ---

# Retrieval server API key. Leave empty (or unset) to disable auth (localhost-only
# deployment). Any non-empty value requires clients to send matching `X-API-Key` header.
RETRIEVAL_API_KEY=

# OpenRouter (required for LLM extraction: Stage B session themes + Stage C per-chunk)
OPENROUTER_API_KEY=
COMMUNITY_BRAIN_LLM_MODEL=google/gemini-3.1-flash-lite-preview

# Ollama endpoint. Inside Docker, the compose default is
# http://host.docker.internal:11434 — override here only if Ollama runs elsewhere.
OLLAMA_BASE_URL=

# --- Optional / other integrations ---

# Fathom API (for historical backfill from the Fathom API; not used by retrieval-server)
FATHOM_API_KEY=

# OpenAI API key (optional, for SP3 cloud embedding alternative)
OPENAI_API_KEY=

# Open WebUI (for SP4 bulk import)
OPEN_WEBUI_URL=http://10.1.50.219:3000

# --- Model / prompt overrides (optional; empty = use extraction-config.yaml) ---
# Precedence: env var > extraction-config.yaml value > built-in default.
# NOTE: switching CHUNK_EXTRACTION_MODEL mid-corpus does not bump
# extraction_prompt_version. Re-ingestion of existing sessions under a
# different model requires force_reextract=true on POST /ingest.

# LLM for per-chunk extraction (Stage C)
COMMUNITY_BRAIN_CHUNK_EXTRACTION_MODEL=
COMMUNITY_BRAIN_CHUNK_EXTRACTION_PROMPT=

# LLM for session-level themes (Stage B)
COMMUNITY_BRAIN_SESSION_THEMES_MODEL=
COMMUNITY_BRAIN_SESSION_THEMES_PROMPT=

# Embedding model (default: nomic-embed-text).
# CRITICAL: changing this after a corpus exists requires full re-embedding
# because vectors from different models are incompatible.
COMMUNITY_BRAIN_EMBED_MODEL=
