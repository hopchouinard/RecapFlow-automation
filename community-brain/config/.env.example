# Copy this file to community-brain/config/.env and uncomment the lines you
# want to set. When running retrieval-server via `docker compose up`, the
# compose file loads this env file automatically (env_file directive).
#
# IMPORTANT: lines are commented with `#` by default so that copying the
# example without edits does NOT inject empty-string env vars into the
# container. Empty strings from env_file OVERRIDE Dockerfile ENV defaults —
# uncommenting a line with an empty value clobbers the container-internal
# default (e.g. OLLAMA_BASE_URL, CONFIG_DIR paths).
#
# Precedence for any variable:
#   1. Runtime -e / shell env at `docker compose up` time  (highest)
#   2. env_file values from THIS file  (only when uncommented)
#   3. Dockerfile ENV defaults  (lowest; applies when no override)

# --- Required for retrieval server deployment ---

# OpenRouter (required for LLM extraction: Stage B session themes + Stage C per-chunk).
# No sensible default; set this or /ingest calls will fail with LLMError.
OPENROUTER_API_KEY=

# Retrieval server API key. Leave UNSET (commented out) to disable auth
# for localhost-only deployments. Any non-empty value requires clients to
# send a matching X-API-Key header.
#RETRIEVAL_API_KEY=your-secret-here

# --- Optional overrides (uncomment only if you need a non-default) ---

# Ollama endpoint. Docker default is http://host.docker.internal:11434
# (set via Dockerfile ENV). Uncomment only if Ollama runs elsewhere.
#OLLAMA_BASE_URL=http://10.1.50.219:11434

# LLM used by the CLI query tool (ollama chat for answer generation).
# Has its own default in code; commented out here.
#COMMUNITY_BRAIN_LLM_MODEL=google/gemini-3.1-flash-lite-preview

# --- Model / prompt overrides for ingestion pipeline ---
# Precedence for these: env var > extraction-config.yaml value > built-in default.
# NOTE: switching CHUNK_EXTRACTION_MODEL mid-corpus does not bump
# extraction_prompt_version. Re-ingestion of existing sessions under a
# different model requires force_reextract=true on POST /ingest.

# LLM for per-chunk extraction (Stage C)
#COMMUNITY_BRAIN_CHUNK_EXTRACTION_MODEL=anthropic/claude-haiku-4-5
#COMMUNITY_BRAIN_CHUNK_EXTRACTION_PROMPT=chunk-extraction-v2.md

# LLM for session-level themes (Stage B)
#COMMUNITY_BRAIN_SESSION_THEMES_MODEL=google/gemini-3.1-flash-lite-preview
#COMMUNITY_BRAIN_SESSION_THEMES_PROMPT=session-themes-v2.md

# Embedding model (default: nomic-embed-text).
# CRITICAL: changing this after a corpus exists requires full re-embedding
# because vectors from different models are incompatible.
#COMMUNITY_BRAIN_EMBED_MODEL=mxbai-embed-large

# --- Other integrations (not required for retrieval-server) ---

# Fathom API (for historical backfill from the Fathom API)
#FATHOM_API_KEY=

# OpenAI API key (optional, for cloud embedding alternative)
#OPENAI_API_KEY=

# Open WebUI host (for bulk import tooling)
#OPEN_WEBUI_URL=http://10.1.50.219:3000
