      "boundElements": null,
      "updated": 1777091719185,
      "link": null,
      "locked": false,
      "fontSize": 12,
      "fontFamily": 5,
      "text": "1. Parser           \u2014 md artifacts \u2192 typed docs\n2. Chunker          \u2014 3 strategies per content type\n3. Stage B          \u2014 session-level LLM extractor\n4. Stage C          \u2014 per-chunk LLM extractor\n5. Embedding        \u2014 Ollama nomic-embed-text\n6. Commit           \u2014 delete-then-add to LanceDB\nIdempotency anchor: extraction_prompt_version",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Parser           \u2014 md artifacts \u2192 typed docs\n2. Chunker          \u2014 3 strategies per content type\n3. Stage B          \u2014 session-level LLM extractor\n4. Stage C          \u2014 per-chunk LLM extractor\n5. Embedding        \u2014 Ollama nomic-embed-text\n6. Commit           \u2014 delete-then-add to LanceDB\nIdempotency anchor: extraction_prompt_version",
      "lineHeight": 1.25,
      "baseline": 10
    },
